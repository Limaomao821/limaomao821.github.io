        <mxCell id="83" parent="1" vertex="1" value="&lt;font color=&quot;#76ff03&quot; style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;SM #39&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#aaaaaa&quot; style=&quot;font-size:10px;&quot;&gt;64C + 8T · 64KB&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;">
